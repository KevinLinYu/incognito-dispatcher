<Window x:Class="IncognitoDispatcher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:p="clr-namespace:IncognitoDispatcher.Properties"
    Title="{x:Static p:Strings.AppName}" Width="480" MinHeight="400" SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    Background="#FAFAFA"
    MaxHeight="700"
    Closing="OnClosing">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{x:Static p:Strings.AppName}" FontSize="22" FontWeight="Bold" Foreground="#1A1A1A"/>
            <TextBlock Style="{StaticResource Secondary}" Text="{x:Static p:Strings.AppSubtitle}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Browser card -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}" Text="{x:Static p:Strings.BrowserSection}"/>
                <TextBlock x:Name="BrowserText" Style="{StaticResource Secondary}" Margin="0,6,0,10" Text="{x:Static p:Strings.BrowserNotSelected}" TextTrimming="CharacterEllipsis" MaxHeight="40"/>
                <Button x:Name="ChangeBrowserBtn" Style="{StaticResource AccentBtn}" Content="{x:Static p:Strings.BrowserSelect}" Click="OnChangeBrowser" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- Settings card -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}" Text="{x:Static p:Strings.SettingsSection}" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <CheckBox x:Name="EnabledCheck" Content="{x:Static p:Strings.SettingsIncognito}" IsChecked="True" Click="OnEnabledClick" VerticalAlignment="Center"/>
                    <CheckBox x:Name="AutoStartCheck" Content="{x:Static p:Strings.SettingsAutoStart}" Margin="24,0,0,0" Click="OnAutoStartClick" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Protocol handler card -->
        <Border Grid.Row="3" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}" Text="{x:Static p:Strings.ProtocolSection}"/>
                <TextBlock x:Name="InstallStatusText" Style="{StaticResource Secondary}" Margin="0,6,0,10" Text="{x:Static p:Strings.ProtocolDetecting}"/>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="InstallBtn" Style="{StaticResource AccentBtn}" Content="{x:Static p:Strings.ProtocolInstall}" Click="OnInstall"/>
                    <Button x:Name="UninstallBtn" Style="{StaticResource SecondaryBtn}" Content="{x:Static p:Strings.ProtocolUninstall}" Click="OnUninstall" Margin="8,0,0,0" IsEnabled="False"/>
                </StackPanel>
                <TextBlock x:Name="ResultText" Style="{StaticResource Secondary}" Margin="0,8,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4" Style="{StaticResource Secondary}" VerticalAlignment="Bottom" Text="{x:Static p:Strings.FooterHint}" FontSize="11"/>
    </Grid>
</Window>
